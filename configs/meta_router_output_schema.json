{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MediaRoutingPackage",
  "type": "object",
  "required": [
    "selected_profile",
    "confidence",
    "detected_chain",
    "priors",
    "runner_up_profiles",
    "notes"
  ],
  "properties": {
    "selected_profile": { "type": "string" },
    "confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
    "detected_medium": {
      "type": "string",
      "enum": [
        "shellac", "vinyl", "tape", "cassette", "cd",
        "dat", "minidisc", "mp3", "streaming_lossy2", "hybrid", "unknown"
      ]
    },
    "detected_chain": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "runner_up_profiles": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "confidence"],
        "properties": {
          "name": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0 }
        }
      }
    },
    "priors": {
      "type": "object",
      "required": [
        "wow_flutter_allowed",
        "denoise_allowed",
        "repair_allowed",
        "codec_taming_required",
        "eq_curve_mode"
      ],
      "properties": {
        "wow_flutter_allowed": { "type": "string", "enum": ["none", "limited", "normal"] },
        "denoise_allowed": { "type": "string", "enum": ["off", "optional", "limited"] },
        "repair_allowed": { "type": "string", "enum": ["low", "medium", "high"] },
        "codec_taming_required": { "type": "boolean" },
        "eq_curve_mode": { "type": "string", "enum": ["none", "riaa", "historical"] }
      }
    },
    "feature_summary": {
      "type": "object",
      "additionalProperties": true
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
